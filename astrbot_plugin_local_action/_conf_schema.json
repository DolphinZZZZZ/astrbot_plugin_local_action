                "condition": {
                  "__allow_rule_channel_scope": true
                },
                "invisible": true
              },
              "channel_scope": {
                "type": "object",
                "description": "渠道范围",
                "condition": {
                  "__allow_rule_channel_scope": true,
                  "use_channel_scope": true
                },
                "invisible": true,
                "items": {
                  "mode": {
                    "type": "string",
                    "default": "global",
                    "description": "范围模式",
                    "options": [
                      "global",
                      "include",
                      "exclude",
                      "custom"
                    ],
                    "labels": [
                      "全局",
                      "包含",
                      "排除",
                      "自定义平台名"
                    ]
                  },
                  "include_channels": {
                    "type": "list",
                    "item_type": "string",
                    "default": [],
                    "description": "包含渠道类型列表",
                    "options": [
                      "qq",
                      "web",
                      "client",
                      "other"
                    ],
                    "condition": {
                      "channel_scope.mode": "include"
                    },
                    "labels": [
                      "QQ",
                      "网页",
                      "客户端",
                      "其他"
                    ]
                  },
                  "exclude_channels": {
                    "type": "list",
                    "item_type": "string",
                    "default": [],
                    "description": "排除渠道类型列表",
                    "options": [
                      "qq",
                      "web",
                      "client",
                      "other"
                    ],
                    "condition": {
                      "channel_scope.mode": "exclude"
                    },
                    "labels": [
                      "QQ",
                      "网页",
                      "客户端",
                      "其他"
                    ]
                  },
                  "platform_names": {
                    "type": "list",
                    "item_type": "string",
                    "default": [],
                    "description": "自定义平台名列表",
                    "condition": {
                      "channel_scope.mode": "custom"
                    }
                  }
                }
              },
              "action": {
                "type": "object",
                "description": "Action",
                "items": {
                  "type": {
                    "type": "string",
                    "default": "screenshot_fullscreen",
                    "description": "动作类型",
                    "options": [
                      "screenshot_fullscreen",
                      "screenshot_window",
                      "list_windows",
                      "read_file",
                      "tail_file",
                      "send_file",
                      "close_process"
                    ],
                    "labels": [
                      "全屏截图",
                      "指定窗口截图",
                      "列出窗口",
                      "读取文件",
                      "读取文件尾部",
                      "发送文件",
                      "关闭匹配窗口进程"
                    ]
                  },
                  "selector": {
                    "type": "object",
                    "default": {},
                    "items": {},
                    "description": "窗口选择器",
                    "hint": "用于 screenshot_window、list_windows、close_process，例如 foreground=true 或 process=Code.exe"
                  },
                  "path": {
                    "type": "string",
                    "default": "",
                    "description": "文件路径",
                    "hint": "用于 read_file、tail_file、send_file；allowed_paths 留空时白名单不生效，填写后路径必须位于白名单内"
                  },
                  "lines": {
                    "type": "int",
                    "default": 100,
                    "description": "读取行数",
                    "hint": "用于 tail_file，读取文件最后多少行",
                    "condition": {
                      "action.type": "tail_file"
                    }
                  },
                  "limit": {
                    "type": "int",
                    "default": 20,
                    "description": "窗口数量上限",
                    "hint": "用于 list_windows。",
                    "condition": {
                      "action.type": "list_windows"
                    }
                  },
                  "force": {
                    "type": "bool",
                    "default": true,
                    "description": "强制关闭",
                    "hint": "用于 close_process，等价于 taskkill /F。",
                    "condition": {
                      "action.type": "close_process"
                    }
                  },
                  "include_children": {
                    "type": "bool",
                    "default": true,
                    "description": "包含子进程",
                    "hint": "用于 close_process，等价于 taskkill /T。",
                    "condition": {
                      "action.type": "close_process"
                    }
                  }
                }
              },
              "confirm": {
                "type": "object",
                "description": "规则级二次确认",
