              "client",
              "other"
            ],
            "condition": {
              "mode": "include"
            },
            "labels": [
              "QQ",
              "网页",
              "客户端",
              "其他"
            ]
          },
          "exclude_channels": {
            "type": "list",
            "item_type": "string",
            "default": [],
            "description": "排除渠道类型列表",
            "options": [
              "qq",
              "web",
              "client",
              "other"
            ],
            "condition": {
              "mode": "exclude"
            },
            "labels": [
              "QQ",
              "网页",
              "客户端",
              "其他"
            ]
          },
          "platform_names": {
            "type": "list",
            "item_type": "string",
            "default": [],
            "description": "自定义平台名列表",
            "condition": {
              "mode": "custom"
            }
          }
        },
        "condition": {
          "enabled": true
        }
      },
      "allowed_paths": {
        "type": "list",
        "item_type": "string",
        "default": [],
        "description": "文件动作白名单路径",
