          {
            "enabled": true,
            "action_name": "屏幕截图",
            "trigger_keywords": [
              "屏幕截图"
            ],
            "match_mode": "contains",
            "__allow_rule_confirm": false,
            "__allow_rule_channel_scope": false,
            "use_channel_scope": false,
            "channel_scope": {
              "mode": "global",
              "include_channels": [],
              "exclude_channels": [],
              "platform_names": []
            },
            "action": {
              "type": "screenshot_fullscreen"
            },
            "__template_key": "rule"
          }
        ],
        "description": "QuickAction 规则列表",
        "condition": {
          "enabled": true
        },
        "templates": {
          "rule": {
            "name": "规则",
            "description": "QuickAction 规则列表",
            "hide_hint_in_list": true,
            "display_item": "action_name",
            "items": {
              "action_name": {
                "type": "string",
                "default": "",
                "description": "动作名称"
              },
              "enabled": {
                "type": "bool",
                "default": true,
                "description": "启用状态"
              },
              "trigger_keywords": {
                "type": "list",
                "item_type": "string",
                "default": [],
                "description": "触发关键词"
              },
              "match_mode": {
                "type": "string",
                "default": "contains",
                "description": "匹配模式",
                "options": [
                  "contains",
                  "exact",
                  "prefix",
                  "regex"
                ],
                "labels": [
                  "包含",
                  "完全匹配",
                  "前缀匹配",
                  "正则"
                ]
              },
              "use_channel_scope": {
                "type": "bool",
                "default": false,
