                  "enabled": {
                    "type": "bool",
                    "default": false,
                    "description": "启用二次确认",
                    "invisible": true
                  },
                  "confirm_text": {
                    "type": "string",
                    "default": "确认",
                    "description": "确认语",
                    "invisible": true
                  },
                  "timeout_seconds": {
                    "type": "int",
                    "default": 30,
                    "description": "确认超时秒数",
                    "invisible": true
                  }
                }
              },
              "__allow_rule_confirm": {
                "type": "bool",
                "default": false,
                "description": "允许规则级二次确认",
                "invisible": true
              },
              "__allow_rule_channel_scope": {
                "type": "bool",
                "default": false,
                "description": "允许单独渠道范围",
                "invisible": true
              }
            }
